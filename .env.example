VITE_ENTER_ANALYTICS_ENABLED=true
VITE_ENTER_ANALYTICS_TOKEN=
VITE_ENTER_PROJECT_ID=
VITE_ENTER_ANALYTICS_ENDPOINT=https://api.enter.pro
VITE_ENTER_ANALYTICS_DEFINITIONS_ENDPOINT=
VITE_ENTER_ANALYTICS_DEBUG=false

# Online multiplayer + leaderboard run on the bundled Elysia backend (same origin,
# WebSocket /ws + REST /api). No client env needed. The server reads DATABASE_URL
# (Shard Cloud Postgres) server-side only — never expose it in a VITE_* var.

# Proximity voice chat needs a TURN relay to connect cross-network behind
# symmetric / carrier-grade NAT (STUN-only ICE fails there). GET /api/turn mints
# time-limited TURN REST credentials (coturn use-auth-secret scheme) from the
# pair below, so the shared secret never ships to the client. Both are OPTIONAL:
# when unset, /api/turn returns only the public STUN server and voice falls back
# to its STUN-only behavior. Configure them against a coturn server started with
# `--use-auth-secret --static-auth-secret=<TURN_SECRET>`.
TURN_SECRET=
TURN_HOST=
